# Required when LLM tasks are implemented. Keep this file committed, but never commit .env.
OPENAI_API_KEY=

# Model names are intentionally user-configured so the repo does not hard-code a paid model choice.
OPENAI_DEFAULT_MODEL=
OPENAI_SMALL_MODEL=
OPENAI_STRONG_MODEL=

# Local-first storage paths.
DATABASE_URL=file:./data/local/app.sqlite
ARTIFACT_ROOT=./data/exports
RAW_IMPORT_ROOT=./data/raw
SCREENSHOT_ROOT=./data/screenshots
DOM_SNAPSHOT_ROOT=./data/dom-snapshots
TRACE_ROOT=./data/traces
LOG_ROOT=./data/logs
BROWSER_PROFILE_DIR=./data/browser-profile

# Safety defaults.
DRY_RUN=true
PLAYWRIGHT_HEADLESS=false
LOG_LEVEL=info
MONTHLY_SOFT_USD_CAP=10
