{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "approval-policies.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["policies"],
  "properties": {
    "$schema": { "type": "string" },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_key",
          "lane_type",
          "host_risk_tier",
          "artifact_review_scope",
          "answer_review_scope",
          "submit_review_scope",
          "allow_batch_artifact_approval",
          "allow_batch_submit_approval",
          "requires_manual_submit_preview",
          "requires_new_answer_review"
        ],
        "properties": {
          "policy_key": { "type": "string", "minLength": 1 },
          "lane_type": {
            "type": "string",
            "enum": ["linkedin_restricted", "ats_lane", "manual_fallback", "unsupported"]
          },
          "host_risk_tier": { "type": "string", "enum": ["low", "medium", "high"] },
          "artifact_review_scope": { "type": "string", "enum": ["per_job", "per_batch"] },
          "answer_review_scope": { "type": "string", "enum": ["per_job", "per_batch"] },
          "submit_review_scope": { "type": "string", "enum": ["per_job", "per_batch"] },
          "allow_batch_artifact_approval": { "type": "boolean" },
          "allow_batch_submit_approval": { "type": "boolean" },
          "requires_manual_submit_preview": { "type": "boolean" },
          "requires_new_answer_review": { "type": "boolean" }
        }
      }
    }
  }
}
